{
  "manifest_version": 3,
  "name": "AI DSA Mentor",
  "version": "1.0",

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}